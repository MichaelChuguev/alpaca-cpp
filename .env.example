# Alpaca API Credentials
# Get your Trading API keys from: https://app.alpaca.markets/paper/dashboard/overview
# For paper trading, use paper trading keys. For live trading, use live keys.

ALPACA_API_KEY=your-api-key-here
ALPACA_SECRET_KEY=your-secret-key-here

# Broker API — Legacy (key/secret) auth
ALPACA_BROKER_API_KEY=your-broker-key-here
ALPACA_BROKER_API_SECRET=your-broker-secret-here

# Broker API — Client credentials auth (recommended, auto token refresh)
ALPACA_BROKER_CLIENT_ID=your-client-id-here
ALPACA_BROKER_CLIENT_SECRET=your-client-secret-here

# Usage:
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys
# 3. Source the environment: source .env (or use direnv)
#
# Note: Never commit your .env file with real credentials.
